{
  "_comment": "SD1.5 multi-image composition workflow using IP-Adapter Plus. Requires: CheckpointLoaderSimple, IPAdapterUnifiedLoader, IPAdapterCombineEmbeds, IPAdapter, CLIPVisionEncode, PrepImageForClipVision, CLIPTextEncode, EmptyLatentImage, KSampler, VAEDecode, SaveImage. Reference image paths injected at runtime. Supports 1-3 reference images.",
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "__CHECKPOINT_NAME__"
    }
  },
  "2": {
    "class_type": "IPAdapterUnifiedLoader",
    "inputs": {
      "model": ["1", 0],
      "preset": "PLUS (high strength)",
      "lora_strength": 0.0
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "__POSITIVE_PROMPT__"
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "__NEGATIVE_PROMPT__"
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "__WIDTH__",
      "height": "__HEIGHT__",
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "__REF_IMAGE_1__"
    }
  },
  "7": {
    "class_type": "PrepImageForClipVision",
    "inputs": {
      "image": ["6", 0],
      "interpolation": "LANCZOS",
      "crop_position": "center",
      "sharpening": 0.0
    }
  },
  "8": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "__REF_IMAGE_2__"
    }
  },
  "9": {
    "class_type": "PrepImageForClipVision",
    "inputs": {
      "image": ["8", 0],
      "interpolation": "LANCZOS",
      "crop_position": "center",
      "sharpening": 0.0
    }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "__REF_IMAGE_3__"
    }
  },
  "11": {
    "class_type": "PrepImageForClipVision",
    "inputs": {
      "image": ["10", 0],
      "interpolation": "LANCZOS",
      "crop_position": "center",
      "sharpening": 0.0
    }
  },
  "12": {
    "class_type": "IPAdapterEncoder",
    "inputs": {
      "ipadapter": ["2", 1],
      "image": ["7", 0],
      "weight": 1.0,
      "mask": null
    }
  },
  "13": {
    "class_type": "IPAdapterEncoder",
    "inputs": {
      "ipadapter": ["2", 1],
      "image": ["9", 0],
      "weight": 1.0,
      "mask": null
    }
  },
  "14": {
    "class_type": "IPAdapterEncoder",
    "inputs": {
      "ipadapter": ["2", 1],
      "image": ["11", 0],
      "weight": 1.0,
      "mask": null
    }
  },
  "15": {
    "class_type": "IPAdapterCombineEmbeds",
    "inputs": {
      "embed1": ["12", 0],
      "embed2": ["13", 0],
      "embed3": ["14", 0],
      "method": "average"
    }
  },
  "16": {
    "class_type": "IPAdapterEmbeds",
    "inputs": {
      "model": ["2", 0],
      "ipadapter": ["2", 1],
      "pos_embed": ["15", 0],
      "weight": "__IPADAPTER_WEIGHT__",
      "weight_type": "linear",
      "start_at": 0.0,
      "end_at": 1.0,
      "embeds_scaling": "V only"
    }
  },
  "17": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["16", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0],
      "seed": "__SEED__",
      "steps": "__STEPS__",
      "cfg": "__CFG__",
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "18": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["17", 0],
      "vae": ["1", 2]
    }
  },
  "19": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["18", 0],
      "filename_prefix": "foxforge_compose"
    }
  }
}
