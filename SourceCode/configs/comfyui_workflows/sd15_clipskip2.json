{
  "_comment": "SD1.5 workflow with CLIP skip 2 for anime models. Inserts CLIPSetLastLayer (stop=-2) between CheckpointLoaderSimple and both CLIPTextEncode nodes. Use for checkpoints that perform better at clip layer -2 (e.g. Anything V3, Counterfeit).",
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "__CHECKPOINT_NAME__"
    }
  },
  "2": {
    "class_type": "CLIPSetLastLayer",
    "inputs": {
      "clip": ["1", 1],
      "stop_at_clip_layer": -2
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "__POSITIVE_PROMPT__"
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "__NEGATIVE_PROMPT__"
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "__WIDTH__",
      "height": "__HEIGHT__",
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0],
      "seed": "__SEED__",
      "steps": "__STEPS__",
      "cfg": "__CFG__",
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["1", 2]
    }
  },
  "8": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["7", 0],
      "filename_prefix": "foxforge_gen"
    }
  }
}
