{
  "_comment": "Stable Video Diffusion XT 1.1 I2V workflow. Requires: ImageOnlyCheckpointLoader, SVD_img2vid_Conditioning, VideoLinearCFGGuidance, KSampler, VAEDecode, VHS_VideoCombine (ComfyUI-VideoHelperSuite). Outputs 25 frames at the configured fps.",
  "1": {
    "class_type": "ImageOnlyCheckpointLoader",
    "inputs": {
      "ckpt_name": "__CHECKPOINT_NAME__"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "__REF_IMAGE__"
    }
  },
  "3": {
    "class_type": "SVD_img2vid_Conditioning",
    "inputs": {
      "clip_vision": ["1", 1],
      "vae": ["1", 2],
      "init_image": ["2", 0],
      "width": "__WIDTH__",
      "height": "__HEIGHT__",
      "video_frames": 25,
      "motion_bucket_id": "__MOTION_BUCKET_ID__",
      "fps": "__FPS__",
      "augmentation_level": 0.0
    }
  },
  "4": {
    "class_type": "VideoLinearCFGGuidance",
    "inputs": {
      "model": ["1", 0],
      "min_cfg": 1.0
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["4", 0],
      "positive": ["3", 0],
      "negative": ["3", 1],
      "latent_image": ["3", 2],
      "seed": "__SEED__",
      "steps": "__STEPS__",
      "cfg": "__CFG__",
      "sampler_name": "euler",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["6", 0],
      "frame_rate": "__FPS__",
      "loop_count": 0,
      "filename_prefix": "foxforge_svd",
      "format": "video/h264-mp4",
      "save_output": true,
      "pingpong": false,
      "save_metadata": true
    }
  }
}
