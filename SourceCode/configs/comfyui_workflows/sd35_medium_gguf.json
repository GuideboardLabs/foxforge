{
  "_comment": "SD3.5 Medium GGUF workflow. Requires: UnetLoaderGGUF (ComfyUI-GGUF), TripleCLIPLoader, CLIPTextEncodeSD3, EmptySD3LatentImage, KSampler, VAELoader, VAEDecode, SaveImage.",
  "1": {
    "class_type": "UnetLoaderGGUF",
    "inputs": {
      "unet_name": "__UNET_NAME__"
    }
  },
  "2": {
    "class_type": "TripleCLIPLoader",
    "inputs": {
      "clip_name1": "__CLIP_L_NAME__",
      "clip_name2": "__CLIP_G_NAME__",
      "clip_name3": "__T5_NAME__"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "__VAE_NAME__"
    }
  },
  "4": {
    "class_type": "CLIPTextEncodeSD3",
    "inputs": {
      "clip": ["2", 0],
      "clip_l": "__POSITIVE_PROMPT__",
      "clip_g": "__POSITIVE_PROMPT__",
      "t5xxl": "__POSITIVE_PROMPT__",
      "empty_padding": "none"
    }
  },
  "5": {
    "class_type": "CLIPTextEncodeSD3",
    "inputs": {
      "clip": ["2", 0],
      "clip_l": "__NEGATIVE_PROMPT__",
      "clip_g": "__NEGATIVE_PROMPT__",
      "t5xxl": "__NEGATIVE_PROMPT__",
      "empty_padding": "none"
    }
  },
  "6": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": "__WIDTH__",
      "height": "__HEIGHT__",
      "batch_size": 1
    }
  },
  "7": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["6", 0],
      "seed": "__SEED__",
      "steps": "__STEPS__",
      "cfg": "__CFG__",
      "sampler_name": "euler",
      "scheduler": "sgm_uniform",
      "denoise": 1.0
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["7", 0],
      "vae": ["3", 0]
    }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["8", 0],
      "filename_prefix": "foxforge_gen"
    }
  }
}
