{
  "_comment": "SD1.5 + CLIP skip 2 + FaceDetailer (ADetailer) for CHR subject. Use for anime checkpoints (Anything V3, Counterfeit) that need clip layer -2 plus a face-fix inpaint pass.",
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "__CHECKPOINT_NAME__"
    }
  },
  "2": {
    "class_type": "CLIPSetLastLayer",
    "inputs": {
      "clip": ["1", 1],
      "stop_at_clip_layer": -2
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "__POSITIVE_PROMPT__"
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "__NEGATIVE_PROMPT__"
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "__WIDTH__",
      "height": "__HEIGHT__",
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0],
      "seed": "__SEED__",
      "steps": "__STEPS__",
      "cfg": "__CFG__",
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["1", 2]
    }
  },
  "8": {
    "class_type": "FaceDetailer",
    "inputs": {
      "image": ["7", 0],
      "model": ["1", 0],
      "clip": ["2", 0],
      "vae": ["1", 2],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "bbox_detector": "bbox/face_yolov8m.pt",
      "sam_model_opt": null,
      "segm_detector_opt": null,
      "detailer_hook": null,
      "guide_size": 384,
      "guide_size_for": true,
      "max_size": 1024,
      "seed": "__SEED__",
      "steps": 20,
      "cfg": "__CFG__",
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.45,
      "feather": 5,
      "noise_mask": true,
      "force_inpaint": true,
      "bbox_threshold": 0.5,
      "bbox_dilation": 10,
      "bbox_crop_factor": 3.0,
      "sam_detection_hint": "center-1",
      "sam_dilation": 0,
      "sam_threshold": 0.93,
      "sam_bbox_expansion": 0,
      "sam_mask_hint_threshold": 0.7,
      "sam_mask_hint_use_negative": "False",
      "drop_size": 10,
      "refiner_ratio": 0.2,
      "cycle": 1,
      "inpaint_model": false,
      "noise_mask_feather": 20
    }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["8", 0],
      "filename_prefix": "foxforge_gen"
    }
  }
}
